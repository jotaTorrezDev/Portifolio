# 🔒 PRODUÇÃO - Copie para .env e preencha com seus valores
# Nunca faça commit de .env com valores reais!

# 🔐 Django
SECRET_KEY=gere-uma-chave-secreta-forte-aqui-use-secrets.token_urlsafe
DEBUG=False
ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com,localhost

# 🛡️ Segurança (Https)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# 🗄️ Banco de Dados (Ajuste se usar PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost/portfolio_db

# 📧 Email (Para contatos)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-app

# 🚀 Deploy Services (Opcional)
HEROKU_APP_NAME=seu-app-heroku
AWS_ACCESS_KEY_ID=sua-chave-aws
AWS_SECRET_ACCESS_KEY=sua-secret-aws
